{
  "name": "demo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\"",
    "dev": "node scripts/free-port-and-dev.cjs",
    "dev:simple": "cross-env NEXT_IGNORE_INCORRECT_LOCKFILE=1 next dev -p 3000",
    "dev:3010": "cross-env NEXT_IGNORE_INCORRECT_LOCKFILE=1 next dev -p 3010",
    "build": "cross-env NEXT_IGNORE_INCORRECT_LOCKFILE=1 next build",
    "start": "cross-env NEXT_IGNORE_INCORRECT_LOCKFILE=1 next start -p 3000",
    "dev:fresh": "npm run clean && node scripts/free-port-and-dev.cjs",
    "dev:reset": "npm run dev:fresh"
  },
  "dependencies": {
    "components": "file:../../packages/components",
    "cross-env": "^10.1.0",
    "next": "14.2.35",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
